# Google Classroom API credentials (required for HTTP transport)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# Server password for OAuth login (required for HTTP transport)
# Set this to any strong password — your daughter enters this when connecting
MCP_AUTH_TOKEN=your_server_password

# Server configuration (optional, Railway sets PORT automatically)
PORT=8000
