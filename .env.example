# Google Cloud OAuth app credentials (shared across all users)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Per-user config: each user gets a password and their own Google refresh token.
# Pattern: USER_<NAME>_PASSWORD and USER_<NAME>_GOOGLE_REFRESH_TOKEN
# The password is what they enter when adding the MCP server in Claude.
# The refresh token comes from running: node index.js auth (with their Google account)

USER_ALICE_PASSWORD=alices_secret_password
USER_ALICE_GOOGLE_REFRESH_TOKEN=alices_google_refresh_token

USER_BOB_PASSWORD=bobs_secret_password
USER_BOB_GOOGLE_REFRESH_TOKEN=bobs_google_refresh_token

# Add more users by following the same pattern:
# USER_CHARLIE_PASSWORD=charlies_password
# USER_CHARLIE_GOOGLE_REFRESH_TOKEN=charlies_token

# Server configuration (optional, Railway sets PORT automatically)
PORT=8000
